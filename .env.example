# ── Tab Backend (.env) ───────────────────────────────────────────────────────
# Kopieren nach .env und Werte setzen. .env ist gitignored.

# SQLite-Datei im Container (gemappt auf /opt/appdata/tab/data in Prod)
DB_PATH=/app/data/tab.db

# Beleg-Uploads im Container (gemappt auf /opt/appdata/tab/uploads in Prod)
UPLOAD_ROOT=/app/uploads
MAX_UPLOAD_MB=10

# ── Single-User-Login ────────────────────────────────────────────────────────
ADMIN_USERNAME=lars
# bcrypt-Hash erzeugen mit:  python3 scripts/hash_password.py
ADMIN_PASSWORD_HASH=

# ── JWT (Bearer-Token) ───────────────────────────────────────────────────────
# Secret erzeugen mit:  openssl rand -hex 32
JWT_SECRET=
JWT_TTL_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# Leer lassen: Frontend ruft same-origin https://tab.vrwb.de/api -> kein CORS nötig.
# Nur setzen, falls das Frontend auf einer anderen Origin läuft (Komma-getrennt).
CORS_ORIGINS=

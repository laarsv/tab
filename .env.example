# ── Tab Backend (.env) ───────────────────────────────────────────────────────
# Kopieren nach .env und Werte setzen. .env ist gitignored.

# SQLite-Datei im Container (gemappt auf /opt/appdata/tab/data in Prod)
DB_PATH=/app/data/tab.db

# Beleg-Uploads im Container (gemappt auf /opt/appdata/tab/uploads in Prod)
UPLOAD_ROOT=/app/uploads
MAX_UPLOAD_MB=10

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Aus der Google Cloud Console (OAuth-2.0-Client, Typ „Web application").
# Autorisierte Redirect-URI dort eintragen: https://tab.vrwb.de/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://tab.vrwb.de/api/auth/callback

# Anmeldung erlaubt für: diese exakten E-Mails (Komma-getrennt) ...
ALLOWED_EMAILS=du@example.com
# ... ODER jede Adresse dieser Domains (Komma-getrennt), z. B. ganzes Team:
# ALLOWED_EMAIL_DOMAINS=example.com
ALLOWED_EMAIL_DOMAINS=

# Frontend-Origin (Rücksprung nach Login/Logout)
FRONTEND_URL=https://tab.vrwb.de

# ── Session / Cookies ────────────────────────────────────────────────────────
# Beide Secrets erzeugen mit:  openssl rand -hex 32
JWT_SECRET=
SESSION_SECRET=
JWT_TTL_DAYS=30
COOKIE_NAME=tab_session
COOKIE_SECURE=true
# COOKIE_DOMAIN nur setzen, falls nötig (leer = Host-Cookie auf tab.vrwb.de)
COOKIE_DOMAIN=

# CORS: leer lassen (Frontend + API same-origin auf https://tab.vrwb.de)
CORS_ORIGINS=

# Offene Registrierung: true = jedes Google-Konto darf sich anmelden
# (ALLOWED_EMAILS bleibt als Admin-Liste aktiv).
OPEN_SIGNUP=false
# Beleg-Speicher-Quota je Nutzer in MB
QUOTA_MB=500
